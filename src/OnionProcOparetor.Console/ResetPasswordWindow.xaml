<Window x:Class="OnionProcOparetor.Console.ResetPasswordWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Reset Password"
        Height="280" Width="420"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Style="{StaticResource AppWindowStyle}">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" x:Name="TitleText" FontSize="16" FontWeight="Bold"/>

        <Border Grid.Row="2" Style="{StaticResource Card}" Background="{StaticResource TableHeaderBgBrush}" Padding="14">
            <StackPanel>
                <TextBlock Text="NEW PASSWORD" Style="{StaticResource LabelText}" FontSize="10"/>
                <TextBlock Text="At least 8 characters."
                           Style="{StaticResource LabelText}" FontSize="10" Margin="0,2,0,8" TextWrapping="Wrap"/>
                <PasswordBox x:Name="NewPasswordBox" Width="250" HorizontalAlignment="Left"/>
            </StackPanel>
        </Border>

        <TextBlock Grid.Row="4" x:Name="StatusText" Style="{StaticResource LabelText}" FontSize="11" TextWrapping="Wrap"/>

        <StackPanel Grid.Row="6" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="RESET" Style="{StaticResource PrimaryButton}"
                    Margin="0,0,8,0" Click="ResetButton_Click"/>
            <Button Content="CANCEL" Style="{StaticResource SmallActionButton}"
                    Click="CancelButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
