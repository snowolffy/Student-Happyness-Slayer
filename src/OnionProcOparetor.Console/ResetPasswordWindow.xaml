<Window x:Class="OnionProcOparetor.Console.ResetPasswordWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Reset Password"
        Height="280" Width="420"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Style="{StaticResource AppWindowStyle}">
    <!-- Free-form Canvas layout - drag any element to reposition it in the VS Designer. -->
    <Canvas Margin="20">
        <TextBlock Canvas.Left="0" Canvas.Top="0" x:Name="TitleText" Style="{StaticResource Heading2}"/>

        <Border Canvas.Left="0" Canvas.Top="32" Width="380" Height="100" CornerRadius="10" Padding="14"
                Background="{StaticResource Brush.Background.Primary}"
                BorderBrush="{StaticResource Brush.Border.Default}" BorderThickness="1">
            <Canvas>
                <TextBlock Canvas.Left="0" Canvas.Top="0" Text="NEW PASSWORD" Style="{StaticResource Label}"/>
                <TextBlock Canvas.Left="0" Canvas.Top="18" Width="324" Text="At least 8 characters."
                           Style="{StaticResource Caption}" TextWrapping="Wrap"/>
                <PasswordBox Canvas.Left="0" Canvas.Top="52" Width="250" x:Name="NewPasswordBox"
                             Style="{StaticResource RoundedPasswordBox}"/>
            </Canvas>
        </Border>

        <TextBlock Canvas.Left="0" Canvas.Top="142" Width="380" x:Name="StatusText" Style="{StaticResource Caption}" TextWrapping="Wrap"/>

        <Button Canvas.Left="222" Canvas.Top="204" Width="70" Content="RESET" Style="{StaticResource ButtonPrimary}"
                Click="ResetButton_Click"/>
        <Button Canvas.Left="300" Canvas.Top="204" Width="80" Content="CANCEL" Style="{StaticResource ButtonSecondary}"
                Padding="10,5" FontSize="11" Click="CancelButton_Click"/>
    </Canvas>
</Window>
