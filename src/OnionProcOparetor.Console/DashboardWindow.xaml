<Window x:Class="OnionProcOparetor.Console.DashboardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Onion ProcOparetor Console - Dashboard"
        Height="680" Width="1000"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Style="{StaticResource AppWindowStyle}"
        Background="{StaticResource Brush.Background.Primary}">
    <!--
        Layout: Toolbar -> TabControl with 4 tabs: CLIENTS / RULES / LOGS / USERS -> footer status bar, all
        positioned on a free-form Canvas (drag any element to reposition it in the VS Designer). Each tab is
        self-contained (its own Canvas + DataGrid) with its own search/filter box and action buttons wired to
        handlers of the same name in DashboardWindow.xaml.cs. Shared DataGrid header/row/cell styles for all 4
        grids are defined once below in Window.Resources instead of repeating them per DataGrid.
        Window is fixed-size (ResizeMode=NoResize) because Canvas positions/sizes are pixel-fixed and would not
        reflow if the window were resized - if you need a resizable Dashboard again, switch back to Grid.
    -->
    <Window.Resources>
        <!-- Shared DataGrid look for all 4 tabs (Clients/Rules/Logs/Users) - kept here instead of
             repeating the same header/row/cell styling inline in every DataGrid.Resources block. -->
        <Style x:Key="ConsoleGridColumnHeaderStyle" TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="{StaticResource Brush.Background.Primary}"/>
            <Setter Property="Foreground" Value="{StaticResource Brush.Text.Secondary}"/>
            <Setter Property="FontFamily" Value="{StaticResource FontFamily.Primary}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="BorderBrush" Value="{StaticResource Brush.Border.Default}"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
        </Style>
        <Style x:Key="ConsoleGridRowStyle" TargetType="DataGridRow">
            <Setter Property="Background" Value="Transparent"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background">
                        <Setter.Value>
                            <SolidColorBrush Color="{StaticResource Color.Accent.Light}" Opacity="0.15"/>
                        </Setter.Value>
                    </Setter>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="ConsoleGridCellStyle" TargetType="DataGridCell">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource Brush.Text.Primary}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="FontFamily" Value="{StaticResource FontFamily.Primary}"/>
            <Setter Property="FontSize" Value="12"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{StaticResource Brush.Background.Primary}"/>
                    <Setter Property="Foreground" Value="{StaticResource Brush.Text.Primary}"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>
    <!-- Free-form Canvas layout - drag any element to reposition it in the VS Designer. -->
    <Canvas Margin="16">

        <!-- ==================== Toolbar (logo/title, last-updated, global actions) ==================== -->
        <Border Canvas.Left="0" Canvas.Top="0" Width="968" Height="60" CornerRadius="12"
                Background="{StaticResource Brush.Background.Card}"
                BorderBrush="{StaticResource Brush.Border.Default}"
                BorderThickness="1" Padding="16,12">
            <Canvas>
                <Border Canvas.Left="0" Canvas.Top="0" Width="36" Height="36" CornerRadius="10"
                        Background="{StaticResource Brush.Accent.Default}">
                    <TextBlock Text="O" FontSize="16" FontWeight="Bold" Foreground="White"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <TextBlock Canvas.Left="46" Canvas.Top="0" Text="Onion ProcOparetor" Style="{StaticResource Heading2}"/>
                <TextBlock Canvas.Left="46" Canvas.Top="20" x:Name="ServerLabel" Text="" Style="{StaticResource Caption}"/>

                <TextBlock Canvas.Left="542" Canvas.Top="10" Width="150" x:Name="StatusText" Style="{StaticResource Caption}"/>

                <Button Canvas.Left="708" Canvas.Top="2" Width="130" x:Name="GlobalToggleButton" Content="TOGGLE GLOBAL"
                        Style="{StaticResource ButtonSecondary}"
                        Click="GlobalToggleButton_Click"/>
                <Button Canvas.Left="846" Canvas.Top="2" Width="90" x:Name="RefreshButton" Content="REFRESH"
                        Style="{StaticResource ButtonSecondary}"
                        Click="RefreshButton_Click"/>
            </Canvas>
        </Border>

        <!-- ==================== Main content ==================== -->
        <Border Canvas.Left="0" Canvas.Top="72" Width="968" Height="516" CornerRadius="12"
                Background="{StaticResource Brush.Background.Card}"
                BorderBrush="{StaticResource Brush.Border.Default}"
                BorderThickness="1" Padding="0">
            <TabControl Width="936" Height="484" Background="Transparent" BorderThickness="0" Margin="16">

                <!-- Local pill-look TabItem template, scoped to this TabControl only.
                     PillTabButton (Theme/Controls.xaml) targets ToggleButton and cannot be applied
                     to TabItem directly (WPF Style.TargetType mismatch), so this reproduces the same
                     shape/colors as a TabItem ControlTemplate instead, without touching Theme/Controls.xaml
                     or AppTheme.xaml, and without changing TabControl's native selection behavior. -->
                <TabControl.Resources>
                    <Style TargetType="TabItem">
                        <Setter Property="Foreground" Value="{StaticResource Brush.Text.Secondary}"/>
                        <Setter Property="FontFamily" Value="{StaticResource FontFamily.Primary}"/>
                        <Setter Property="FontWeight" Value="SemiBold"/>
                        <Setter Property="FontSize" Value="12"/>
                        <Setter Property="Padding" Value="18,8"/>
                        <Setter Property="Margin" Value="0,0,8,0"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="TabItem">
                                    <Border x:Name="Bd" CornerRadius="16"
                                            Background="Transparent"
                                            BorderBrush="{StaticResource Brush.Border.Default}"
                                            BorderThickness="1"
                                            Padding="{TemplateBinding Padding}">
                                        <ContentPresenter ContentSource="Header" HorizontalAlignment="Center" VerticalAlignment="Center"
                                                          TextElement.Foreground="{TemplateBinding Foreground}"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource Brush.Accent.Default}"/>
                                            <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource Brush.Accent.Default}"/>
                                            <Setter Property="Foreground" Value="White"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </TabControl.Resources>

                <!-- ========== Clients tab ========== -->
                <TabItem Header="CLIENTS">
                    <Canvas Margin="0,12,0,0">
                        <TextBlock Canvas.Left="0" Canvas.Top="0" Text="Client Management" Style="{StaticResource Heading2}"/>
                        <Button Canvas.Left="170" Canvas.Top="-4" Width="150" Content="TOGGLE SELECTED" Style="{StaticResource ButtonSecondary}"
                                Padding="10,5" FontSize="11"
                                Click="ToggleSelectedClientsButton_Click"/>
                        <Button Canvas.Left="330" Canvas.Top="-4" Width="180" Content="BROADCAST MESSAGE" Style="{StaticResource ButtonSecondary}"
                                Padding="10,5" FontSize="11"
                                Click="BroadcastMessageButton_Click"/>
                        <TextBlock Canvas.Left="520" Canvas.Top="2" x:Name="SelectedClientsCountText"
                                Foreground="{StaticResource Brush.Text.Secondary}" Text=""/>

                        <TextBox Canvas.Left="0" Canvas.Top="44" x:Name="ClientsSearchBox" Width="250"
                                Style="{StaticResource RoundedTextBox}"
                                Tag="ค้นหา machine name..." TextChanged="ClientsSearchBox_TextChanged"/>

                        <DataGrid Canvas.Left="0" Canvas.Top="84" Width="936" Height="356" x:Name="ClientsGrid" AutoGenerateColumns="False" IsReadOnly="True"
                                SelectionMode="Extended" SelectionUnit="FullRow"
                                SelectionChanged="ClientsGrid_SelectionChanged"
                                Background="{StaticResource Brush.Background.Card}"
                                BorderBrush="{StaticResource Brush.Border.Default}" BorderThickness="1"
                                RowBackground="{StaticResource Brush.Background.Card}"
                                AlternatingRowBackground="{StaticResource Brush.Background.Card}"
                                HorizontalGridLinesBrush="{StaticResource Brush.Border.Default}"
                                VerticalGridLinesBrush="{StaticResource Brush.Border.Default}"
                                RowHeight="40" CanUserAddRows="False"
                                ColumnHeaderStyle="{StaticResource ConsoleGridColumnHeaderStyle}"
                                RowStyle="{StaticResource ConsoleGridRowStyle}"
                                CellStyle="{StaticResource ConsoleGridCellStyle}">
                            <DataGrid.Resources>
                                <!-- Status badge: no "Status" string property exists on ClientMachineDto (only
                                     IsEnabled/IsOffline booleans) - this reproduces the exact 3-state logic the
                                     original status Ellipse used (Offline wins over Enabled), expressed as
                                     StatusBadge's Tag rather than a nonexistent Status binding. -->
                                <Style x:Key="ClientStatusBadge" TargetType="ContentControl" BasedOn="{StaticResource StatusBadge}">
                                    <Setter Property="Tag" Value="Danger"/>
                                    <Setter Property="Content" Value="DISABLED"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsEnabled}" Value="True">
                                            <Setter Property="Tag" Value="Online"/>
                                            <Setter Property="Content" Value="ONLINE"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding IsOffline}" Value="True">
                                            <Setter Property="Tag" Value="Offline"/>
                                            <Setter Property="Content" Value="OFFLINE"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGrid.Resources>
                            <DataGrid.Columns>
                                <DataGridTemplateColumn Header="STATUS" Width="90" SortMemberPath="IsOffline">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <ContentControl Style="{StaticResource ClientStatusBadge}"
                                                            ToolTip="{Binding LastSeenAt, StringFormat='Last seen: {0:yyyy-MM-dd HH:mm:ss} UTC'}"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTemplateColumn Header="MACHINE NAME" Width="180">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding MachineName}" TextTrimming="CharacterEllipsis"
                                                       ToolTip="{Binding MachineName}" VerticalAlignment="Center"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTemplateColumn Header="CLIENT GUID" Width="240">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding ClientGuid}" TextTrimming="CharacterEllipsis"
                                                       ToolTip="{Binding ClientGuid}" VerticalAlignment="Center"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTextColumn Header="LAST SEEN (UTC)" Binding="{Binding LastSeenAt}" Width="170"/>
                                <DataGridTemplateColumn Header="ACTION" Width="240">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal">
                                                <Button Content="TOGGLE" Style="{StaticResource ButtonSecondary}"
                                                        Padding="10,5" FontSize="11"
                                                        Click="ToggleClientButton_Click" Tag="{Binding Id}" Margin="0,0,4,0"/>
                                                <Button Content="SETTINGS" Style="{StaticResource ButtonSecondary}"
                                                        Padding="10,5" FontSize="11"
                                                        Click="ClientSettingsButton_Click" Tag="{Binding}" Margin="0,0,4,0"/>
                                                <Button Content="DELETE" Style="{StaticResource ButtonDanger}"
                                                        Padding="10,5" FontSize="11"
                                                        Click="DeleteClientButton_Click" Tag="{Binding Id}"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Canvas>
                </TabItem>

                <!-- ========== Rules tab ========== -->
                <TabItem Header="RULES">
                    <Canvas Margin="0,12,0,0">
                        <TextBlock Canvas.Left="0" Canvas.Top="0" Text="Rule Management" Style="{StaticResource Heading2}"/>

                        <Border Canvas.Left="0" Canvas.Top="32" Width="936" Height="56" CornerRadius="10"
                                Background="{StaticResource Brush.Background.Primary}"
                                BorderBrush="{StaticResource Brush.Border.Default}"
                                BorderThickness="1" Padding="12">
                            <Canvas>
                                <TextBox Canvas.Left="0" Canvas.Top="0" x:Name="NewRuleNameBox" Width="110"
                                        Style="{StaticResource RoundedTextBox}"
                                        ToolTip="ชื่อกฎ" Tag="Rule name"/>
                                <TextBox Canvas.Left="118" Canvas.Top="0" x:Name="NewRulePublisherBox" Width="160"
                                        Style="{StaticResource RoundedTextBox}"
                                        ToolTip="ชื่อ Publisher เช่น Valve Corporation"/>
                                <TextBox Canvas.Left="286" Canvas.Top="0" x:Name="NewRuleProcessNameContainsBox" Width="130"
                                        Style="{StaticResource RoundedTextBox}"
                                        ToolTip="[OPTIONAL] narrow เพิ่มจากชื่อไฟล์ เช่น 'notepad' - เว้นว่างได้ถ้าไม่รู้ชื่อไฟล์ล่วงหน้า"/>
                                <CheckBox Canvas.Left="424" Canvas.Top="8" x:Name="NewRuleKillCheckBox" Content="Kill Process"
                                        Foreground="{StaticResource Brush.Text.Primary}"/>
                                <TextBox Canvas.Left="542" Canvas.Top="0" x:Name="NewRuleActionBox" Width="150"
                                        Style="{StaticResource RoundedTextBox}"
                                        ToolTip="path คำสั่ง/สคริปต์ (ไม่บังคับ)"/>
                                <Button Canvas.Left="700" Canvas.Top="0" Content="ADD RULE" Style="{StaticResource ButtonPrimary}"
                                        Click="AddRuleButton_Click"/>
                            </Canvas>
                        </Border>

                        <TextBox Canvas.Left="0" Canvas.Top="104" x:Name="RulesSearchBox" Width="250"
                                Style="{StaticResource RoundedTextBox}"
                                Tag="ค้นหาชื่อกฎ/publisher..." TextChanged="RulesSearchBox_TextChanged"/>

                        <DataGrid Canvas.Left="0" Canvas.Top="144" Width="936" Height="296" x:Name="RulesGrid" AutoGenerateColumns="False" IsReadOnly="True"
                                Background="{StaticResource Brush.Background.Card}"
                                BorderBrush="{StaticResource Brush.Border.Default}" BorderThickness="1"
                                RowBackground="{StaticResource Brush.Background.Card}"
                                AlternatingRowBackground="{StaticResource Brush.Background.Card}"
                                HorizontalGridLinesBrush="{StaticResource Brush.Border.Default}"
                                VerticalGridLinesBrush="{StaticResource Brush.Border.Default}"
                                RowHeight="40" CanUserAddRows="False"
                                ColumnHeaderStyle="{StaticResource ConsoleGridColumnHeaderStyle}"
                                RowStyle="{StaticResource ConsoleGridRowStyle}"
                                CellStyle="{StaticResource ConsoleGridCellStyle}">
                            <DataGrid.Resources>
                                <Style x:Key="RuleStatusBadge" TargetType="ContentControl" BasedOn="{StaticResource StatusBadge}">
                                    <Setter Property="Tag" Value="Danger"/>
                                    <Setter Property="Content" Value="DISABLED"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsEnabled}" Value="True">
                                            <Setter Property="Tag" Value="Online"/>
                                            <Setter Property="Content" Value="ENABLED"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGrid.Resources>
                            <DataGrid.Columns>
                                <DataGridTemplateColumn Header="STATUS" Width="90" SortMemberPath="IsEnabled">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <ContentControl Style="{StaticResource RuleStatusBadge}"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTextColumn Header="NAME" Binding="{Binding Name}" Width="130"/>
                                <DataGridTextColumn Header="PUBLISHER" Binding="{Binding PublisherName}" Width="170"/>
                                <DataGridTextColumn Header="NAME CONTAINS" Binding="{Binding ProcessNameContains}" Width="110"/>
                                <DataGridTextColumn Header="SIGNED ONLY" Binding="{Binding RequireSignedMatch}" Width="90"/>
                                <DataGridTextColumn Header="KILL" Binding="{Binding KillProcess}" Width="50"/>
                                <DataGridTextColumn Header="ACTION COMMAND" Binding="{Binding ActionCommand}" Width="150"/>
                                <DataGridTemplateColumn Header="ACTIONS" Width="160">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal">
                                                <Button Content="TOGGLE" Style="{StaticResource ButtonSecondary}"
                                                        Padding="10,5" FontSize="11"
                                                        Click="ToggleRuleButton_Click" Tag="{Binding Id}" Margin="0,0,4,0"/>
                                                <Button Content="DELETE" Style="{StaticResource ButtonDanger}"
                                                        Padding="10,5" FontSize="11"
                                                        Click="DeleteRuleButton_Click" Tag="{Binding Id}"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                             </DataGrid.Columns>
                        </DataGrid>
                    </Canvas>
                </TabItem>

                <!-- ========== Logs tab ========== -->
                <TabItem Header="LOGS">
                    <Canvas Margin="0,12,0,0">
                        <TextBlock Canvas.Left="0" Canvas.Top="0" Text="Activity Logs" Style="{StaticResource Heading2}"/>

                        <TextBox Canvas.Left="0" Canvas.Top="32" x:Name="LogsSearchBox" Width="250"
                                Style="{StaticResource RoundedTextBox}"
                                Tag="ค้นหา machine/process/publisher..." TextChanged="LogsSearchBox_TextChanged"/>

                        <DataGrid Canvas.Left="0" Canvas.Top="72" Width="936" Height="368" x:Name="LogsGrid" AutoGenerateColumns="False" IsReadOnly="True"
                                Background="{StaticResource Brush.Background.Card}"
                                BorderBrush="{StaticResource Brush.Border.Default}" BorderThickness="1"
                                RowBackground="{StaticResource Brush.Background.Card}"
                                AlternatingRowBackground="{StaticResource Brush.Background.Card}"
                                HorizontalGridLinesBrush="{StaticResource Brush.Border.Default}"
                                VerticalGridLinesBrush="{StaticResource Brush.Border.Default}"
                                RowHeight="40" CanUserAddRows="False"
                                ColumnHeaderStyle="{StaticResource ConsoleGridColumnHeaderStyle}"
                                RowStyle="{StaticResource ConsoleGridRowStyle}"
                                CellStyle="{StaticResource ConsoleGridCellStyle}">
                            <DataGrid.Resources>
                                <Style x:Key="LogSignedBadge" TargetType="ContentControl" BasedOn="{StaticResource StatusBadge}">
                                    <Setter Property="Tag" Value="Danger"/>
                                    <Setter Property="Content" Value="UNSIGNED"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding WasSignedMatch}" Value="True">
                                            <Setter Property="Tag" Value="Online"/>
                                            <Setter Property="Content" Value="SIGNED"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGrid.Resources>
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="TIME (UTC)" Binding="{Binding Timestamp}" Width="150"/>
                                <DataGridTextColumn Header="MACHINE" Binding="{Binding MachineName}" Width="130"/>
                                <DataGridTextColumn Header="PROCESS" Binding="{Binding ProcessPath}" Width="220"/>
                                <DataGridTextColumn Header="PUBLISHER" Binding="{Binding DetectedPublisher}" Width="160"/>
                                <DataGridTemplateColumn Header="SIGNED" Width="90" SortMemberPath="WasSignedMatch">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <ContentControl Style="{StaticResource LogSignedBadge}"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTextColumn Header="RULE" Binding="{Binding MatchedRuleName}" Width="120"/>
                                <DataGridTextColumn Header="ACTION TAKEN" Binding="{Binding ActionTaken}" Width="150"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Canvas>
                </TabItem>

                <!-- ========== Users tab ========== -->
                <TabItem Header="USERS">
                    <Canvas Margin="0,12,0,0">
                        <TextBlock Canvas.Left="0" Canvas.Top="0" Text="User Management" Style="{StaticResource Heading2}"/>

                        <Border Canvas.Left="0" Canvas.Top="32" Width="936" Height="56" CornerRadius="10"
                                Background="{StaticResource Brush.Background.Primary}"
                                BorderBrush="{StaticResource Brush.Border.Default}"
                                BorderThickness="1" Padding="12">
                            <Canvas>
                                <TextBox Canvas.Left="0" Canvas.Top="0" x:Name="NewUserUsernameBox" Width="160"
                                         Style="{StaticResource RoundedTextBox}"
                                         ToolTip="Username"/>
                                <PasswordBox Canvas.Left="168" Canvas.Top="0" x:Name="NewUserPasswordBox" Width="160"
                                             Style="{StaticResource RoundedPasswordBox}"
                                             ToolTip="Password (อย่างน้อย 8 ตัวอักษร)"/>
                                <Button Canvas.Left="336" Canvas.Top="0" Content="ADD USER" Style="{StaticResource ButtonPrimary}"
                                        Click="AddUserButton_Click"/>
                            </Canvas>
                        </Border>

                        <DataGrid Canvas.Left="0" Canvas.Top="104" Width="936" Height="336" x:Name="UsersGrid" AutoGenerateColumns="False" IsReadOnly="True"
                                Background="{StaticResource Brush.Background.Card}"
                                BorderBrush="{StaticResource Brush.Border.Default}" BorderThickness="1"
                                RowBackground="{StaticResource Brush.Background.Card}"
                                AlternatingRowBackground="{StaticResource Brush.Background.Card}"
                                HorizontalGridLinesBrush="{StaticResource Brush.Border.Default}"
                                VerticalGridLinesBrush="{StaticResource Brush.Border.Default}"
                                RowHeight="40" CanUserAddRows="False"
                                ColumnHeaderStyle="{StaticResource ConsoleGridColumnHeaderStyle}"
                                RowStyle="{StaticResource ConsoleGridRowStyle}"
                                CellStyle="{StaticResource ConsoleGridCellStyle}">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="USERNAME" Binding="{Binding Username}" Width="150"/>
                                <DataGridTextColumn Header="BUILT-IN" Binding="{Binding IsBuiltIn}" Width="80"/>
                                <DataGridTextColumn Header="DEFAULT PASSWORD" Binding="{Binding HasDefaultPassword}" Width="130"/>
                                <DataGridTextColumn Header="CREATED (UTC)" Binding="{Binding CreatedAt}" Width="160"/>
                                <DataGridTextColumn Header="LAST LOGIN (UTC)" Binding="{Binding LastLoginAt}" Width="160"/>
                                <DataGridTemplateColumn Header="ACTIONS" Width="220">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal">
                                                <!--
                                                    ปุ่ม RESET PW: ใช้ได้กับทุก account รวม built-in
                                                    (ต่างจาก DELETE ที่ต้องกันไว้เพราะลบ built-in ไม่ได้เลย)
                                                -->
                                                <Button Content="RESET PW" Tag="{Binding}"
                                                        Click="ResetUserPasswordButton_Click"
                                                        Style="{StaticResource ButtonSecondary}"
                                                        Padding="10,5" FontSize="11"
                                                        Margin="0,0,4,0"/>

                                                <!--
                                                    ปุ่ม DELETE: disable ถ้าเป็น built-in account (กัน lockout)
                                                    ใช้ DataTrigger เทียบ IsBuiltIn แทนการเขียน converter class ใหม่
                                                -->
                                                <Button Content="DELETE" Tag="{Binding Id}"
                                                        Click="DeleteUserButton_Click"
                                                        Padding="10,5" FontSize="11">
                                                    <Button.Style>
                                                        <Style TargetType="Button" BasedOn="{StaticResource ButtonDanger}">
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsBuiltIn}" Value="True">
                                                                    <Setter Property="IsEnabled" Value="False"/>
                                                                    <Setter Property="ToolTip" Value="ลบ built-in account ไม่ได้"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Button.Style>
                                                </Button>
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Canvas>
                </TabItem>

            </TabControl>
        </Border>

        <!-- ==================== Footer status bar ==================== -->
        <Border Canvas.Left="0" Canvas.Top="596" Width="968" Height="52" CornerRadius="12"
                Background="{StaticResource Brush.Background.Card}"
                BorderBrush="{StaticResource Brush.Border.Default}"
                BorderThickness="1" Padding="16,10">
            <Canvas>
                <TextBlock Canvas.Left="0" Canvas.Top="8" Text="Server:" Style="{StaticResource Label}"/>
                <TextBlock Canvas.Left="46" Canvas.Top="8" Width="300" x:Name="FooterServerText" Style="{StaticResource Caption}"/>
                <TextBlock Canvas.Left="360" Canvas.Top="8" Text="User:" Style="{StaticResource Label}"/>
                <TextBlock Canvas.Left="400" Canvas.Top="8" Width="200" x:Name="FooterUserText" Style="{StaticResource Caption}"/>
            </Canvas>
        </Border>
    </Canvas>
</Window>
