<Window x:Class="OnionProcOparetor.Console.DashboardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Onion ProcOparetor Console - Dashboard"
        Height="680" Width="1000"
        WindowStartupLocation="CenterScreen"
        Style="{StaticResource AppWindowStyle}"
        Background="{StaticResource Brush.Background.Primary}">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="8"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ==================== Toolbar (logo/title, last-updated, global actions) ==================== -->
        <Border Grid.Row="0" CornerRadius="12"
                Background="{StaticResource Brush.Background.Card}"
                BorderBrush="{StaticResource Brush.Border.Default}"
                BorderThickness="1" Padding="16,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <Border Width="36" Height="36" CornerRadius="10"
                            Background="{StaticResource Brush.Accent.Default}">
                        <TextBlock Text="O" FontSize="16" FontWeight="Bold" Foreground="White"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel Margin="10,0,0,0" VerticalAlignment="Center">
                        <TextBlock Text="Onion ProcOparetor" Style="{StaticResource Heading2}"/>
                        <TextBlock x:Name="ServerLabel" Text="" Style="{StaticResource Caption}"/>
                    </StackPanel>
                </StackPanel>

                <TextBlock Grid.Column="2" x:Name="StatusText" Style="{StaticResource Caption}"
                           VerticalAlignment="Center" Margin="0,0,16,0"/>

                <StackPanel Grid.Column="3" Orientation="Horizontal">
                    <Button x:Name="GlobalToggleButton" Content="TOGGLE GLOBAL"
                            Style="{StaticResource ButtonSecondary}" Margin="0,0,8,0"
                            Click="GlobalToggleButton_Click"/>
                    <Button x:Name="RefreshButton" Content="REFRESH"
                            Style="{StaticResource ButtonSecondary}"
                            Click="RefreshButton_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ==================== Main content ==================== -->
        <Border Grid.Row="2" CornerRadius="12"
                Background="{StaticResource Brush.Background.Card}"
                BorderBrush="{StaticResource Brush.Border.Default}"
                BorderThickness="1" Padding="0">
            <TabControl Background="Transparent" BorderThickness="0" Margin="16">

                <!-- Local pill-look TabItem template, scoped to this TabControl only.
                     PillTabButton (Theme/Controls.xaml) targets ToggleButton and cannot be applied
                     to TabItem directly (WPF Style.TargetType mismatch), so this reproduces the same
                     shape/colors as a TabItem ControlTemplate instead, without touching Theme/Controls.xaml
                     or AppTheme.xaml, and without changing TabControl's native selection behavior. -->
                <TabControl.Resources>
                    <Style TargetType="TabItem">
                        <Setter Property="Foreground" Value="{StaticResource Brush.Text.Secondary}"/>
                        <Setter Property="FontFamily" Value="{StaticResource FontFamily.Primary}"/>
                        <Setter Property="FontWeight" Value="SemiBold"/>
                        <Setter Property="FontSize" Value="12"/>
                        <Setter Property="Padding" Value="18,8"/>
                        <Setter Property="Margin" Value="0,0,8,0"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="TabItem">
                                    <Border x:Name="Bd" CornerRadius="16"
                                            Background="Transparent"
                                            BorderBrush="{StaticResource Brush.Border.Default}"
                                            BorderThickness="1"
                                            Padding="{TemplateBinding Padding}">
                                        <ContentPresenter ContentSource="Header" HorizontalAlignment="Center" VerticalAlignment="Center"
                                                          TextElement.Foreground="{TemplateBinding Foreground}"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource Brush.Accent.Default}"/>
                                            <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource Brush.Accent.Default}"/>
                                            <Setter Property="Foreground" Value="White"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </TabControl.Resources>

                <!-- ========== Clients tab ========== -->
                <TabItem Header="CLIENTS">
                    <Grid Margin="0,12,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="12"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="8"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Orientation="Horizontal">
                            <TextBlock Text="Client Management" Style="{StaticResource Heading2}" VerticalAlignment="Center"/>
                            <Button Content="TOGGLE SELECTED" Style="{StaticResource ButtonSecondary}"
                                    Padding="10,5" FontSize="11"
                                    Margin="16,0,0,0" Click="ToggleSelectedClientsButton_Click"/>
                            <TextBlock x:Name="SelectedClientsCountText" VerticalAlignment="Center" Margin="8,0,0,0"
                                    Foreground="{StaticResource Brush.Text.Secondary}" Text=""/>
                        </StackPanel>

                        <TextBox Grid.Row="2" x:Name="ClientsSearchBox" Width="250" HorizontalAlignment="Left"
                                Style="{StaticResource RoundedTextBox}"
                                Tag="ค้นหา machine name..." TextChanged="ClientsSearchBox_TextChanged"/>

                        <DataGrid Grid.Row="4" x:Name="ClientsGrid" AutoGenerateColumns="False" IsReadOnly="True"
                                SelectionMode="Extended" SelectionUnit="FullRow"
                                SelectionChanged="ClientsGrid_SelectionChanged"
                                Background="{StaticResource Brush.Background.Card}"
                                BorderBrush="{StaticResource Brush.Border.Default}" BorderThickness="1"
                                RowBackground="{StaticResource Brush.Background.Card}"
                                AlternatingRowBackground="{StaticResource Brush.Background.Card}"
                                HorizontalGridLinesBrush="{StaticResource Brush.Border.Default}"
                                VerticalGridLinesBrush="{StaticResource Brush.Border.Default}"
                                RowHeight="40" CanUserAddRows="False">
                            <DataGrid.Resources>
                                <!-- Status badge: no "Status" string property exists on ClientMachineDto (only
                                     IsEnabled/IsOffline booleans) - this reproduces the exact 3-state logic the
                                     original status Ellipse used (Offline wins over Enabled), expressed as
                                     StatusBadge's Tag rather than a nonexistent Status binding. -->
                                <Style x:Key="ClientStatusBadge" TargetType="ContentControl" BasedOn="{StaticResource StatusBadge}">
                                    <Setter Property="Tag" Value="Danger"/>
                                    <Setter Property="Content" Value="DISABLED"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsEnabled}" Value="True">
                                            <Setter Property="Tag" Value="Online"/>
                                            <Setter Property="Content" Value="ONLINE"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding IsOffline}" Value="True">
                                            <Setter Property="Tag" Value="Offline"/>
                                            <Setter Property="Content" Value="OFFLINE"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                                <Style TargetType="DataGridColumnHeader">
                                    <Setter Property="Background" Value="{StaticResource Brush.Background.Primary}"/>
                                    <Setter Property="Foreground" Value="{StaticResource Brush.Text.Secondary}"/>
                                    <Setter Property="FontFamily" Value="{StaticResource FontFamily.Primary}"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                    <Setter Property="FontSize" Value="11"/>
                                    <Setter Property="Padding" Value="10,8"/>
                                    <Setter Property="BorderBrush" Value="{StaticResource Brush.Border.Default}"/>
                                    <Setter Property="BorderThickness" Value="0,0,1,1"/>
                                </Style>
                                <Style TargetType="DataGridRow">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background">
                                                <Setter.Value>
                                                    <SolidColorBrush Color="{StaticResource Color.Accent.Light}" Opacity="0.15"/>
                                                </Setter.Value>
                                            </Setter>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                                <Style TargetType="DataGridCell">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="Foreground" Value="{StaticResource Brush.Text.Primary}"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="Padding" Value="10,4"/>
                                    <Setter Property="FontFamily" Value="{StaticResource FontFamily.Primary}"/>
                                    <Setter Property="FontSize" Value="12"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter Property="Background" Value="{StaticResource Brush.Background.Primary}"/>
                                            <Setter Property="Foreground" Value="{StaticResource Brush.Text.Primary}"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGrid.Resources>
                            <DataGrid.Columns>
                                <DataGridTemplateColumn Header="STATUS" Width="90" SortMemberPath="IsOffline">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <ContentControl Style="{StaticResource ClientStatusBadge}"
                                                            ToolTip="{Binding LastSeenAt, StringFormat='Last seen: {0:yyyy-MM-dd HH:mm:ss} UTC'}"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTemplateColumn Header="MACHINE NAME" Width="180">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding MachineName}" TextTrimming="CharacterEllipsis"
                                                       ToolTip="{Binding MachineName}" VerticalAlignment="Center"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTemplateColumn Header="CLIENT GUID" Width="240">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding ClientGuid}" TextTrimming="CharacterEllipsis"
                                                       ToolTip="{Binding ClientGuid}" VerticalAlignment="Center"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTextColumn Header="LAST SEEN (UTC)" Binding="{Binding LastSeenAt}" Width="170"/>
                                <DataGridTemplateColumn Header="ACTION" Width="240">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal">
                                                <Button Content="TOGGLE" Style="{StaticResource ButtonSecondary}"
                                                        Padding="10,5" FontSize="11"
                                                        Click="ToggleClientButton_Click" Tag="{Binding Id}" Margin="0,0,4,0"/>
                                                <Button Content="SETTINGS" Style="{StaticResource ButtonSecondary}"
                                                        Padding="10,5" FontSize="11"
                                                        Click="ClientSettingsButton_Click" Tag="{Binding}" Margin="0,0,4,0"/>
                                                <Button Content="DELETE" Style="{StaticResource ButtonDanger}"
                                                        Padding="10,5" FontSize="11"
                                                        Click="DeleteClientButton_Click" Tag="{Binding Id}"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </TabItem>

                <!-- ========== Rules tab ========== -->
                <TabItem Header="RULES">
                    <Grid Margin="0,12,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="12"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="8"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0" Style="{StaticResource Card}" Background="{StaticResource TableHeaderBgBrush}" Padding="12">
                            <StackPanel Orientation="Horizontal">
                                <TextBox x:Name="NewRuleNameBox" Width="110" Margin="0,0,8,0"
                                        ToolTip="ชื่อกฎ" Tag="Rule name"/>
                                <TextBox x:Name="NewRulePublisherBox" Width="160" Margin="0,0,8,0"
                                        ToolTip="ชื่อ Publisher เช่น Valve Corporation"/>
                                <TextBox x:Name="NewRuleProcessNameContainsBox" Width="130" Margin="0,0,8,0"
                                        ToolTip="[OPTIONAL] narrow เพิ่มจากชื่อไฟล์ เช่น 'notepad' - เว้นว่างได้ถ้าไม่รู้ชื่อไฟล์ล่วงหน้า"/>
                                <CheckBox x:Name="NewRuleKillCheckBox" Content="Kill Process"
                                        VerticalAlignment="Center" Margin="0,0,8,0" Foreground="{StaticResource TextPrimaryBrush}"/>
                                <TextBox x:Name="NewRuleActionBox" Width="150" Margin="0,0,8,0"
                                        ToolTip="path คำสั่ง/สคริปต์ (ไม่บังคับ)"/>
                                <Button Content="ADD RULE" Style="{StaticResource PrimaryButton}"
                                        Click="AddRuleButton_Click"/>
                            </StackPanel>
                        </Border>

                        <TextBox Grid.Row="2" x:Name="RulesSearchBox" Width="250" HorizontalAlignment="Left"
                                Tag="ค้นหาชื่อกฎ/publisher..." TextChanged="RulesSearchBox_TextChanged"/>

                        <DataGrid Grid.Row="4" x:Name="RulesGrid" AutoGenerateColumns="False" IsReadOnly="True">
                            <DataGrid.Columns>
                                <DataGridTemplateColumn Header="STATUS" Width="80" SortMemberPath="IsEnabled">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Ellipse Width="10" Height="10" HorizontalAlignment="Center">
                                                <Ellipse.Style>
                                                    <Style TargetType="Ellipse">
                                                        <Setter Property="Fill" Value="{StaticResource AccentRedBrush}"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsEnabled}" Value="True">
                                                                <Setter Property="Fill" Value="{StaticResource AccentGreenBrush}"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Ellipse.Style>
                                            </Ellipse>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTextColumn Header="NAME" Binding="{Binding Name}" Width="130"/>
                                <DataGridTextColumn Header="PUBLISHER" Binding="{Binding PublisherName}" Width="170"/>
                                <DataGridTextColumn Header="NAME CONTAINS" Binding="{Binding ProcessNameContains}" Width="110"/>
                                <DataGridTextColumn Header="SIGNED ONLY" Binding="{Binding RequireSignedMatch}" Width="90"/>
                                <DataGridTextColumn Header="KILL" Binding="{Binding KillProcess}" Width="50"/>
                                <DataGridTextColumn Header="ACTION COMMAND" Binding="{Binding ActionCommand}" Width="150"/>
                                <DataGridTemplateColumn Header="ACTIONS" Width="140">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal">
                                                <Button Content="TOGGLE" Style="{StaticResource SmallActionButton}"
                                                        Click="ToggleRuleButton_Click" Tag="{Binding Id}" Margin="0,0,4,0"/>
                                                <Button Content="DELETE" Style="{StaticResource DangerSmallActionButton}"
                                                        Click="DeleteRuleButton_Click" Tag="{Binding Id}"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                             </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </TabItem>

                <!-- ========== Logs tab ========== -->
                <TabItem Header="LOGS">
                    <Grid Margin="0,12,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="8"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <TextBox Grid.Row="0" x:Name="LogsSearchBox" Width="250" HorizontalAlignment="Left"
                                Tag="ค้นหา machine/process/publisher..." TextChanged="LogsSearchBox_TextChanged"/>

                        <DataGrid Grid.Row="2" x:Name="LogsGrid" AutoGenerateColumns="False" IsReadOnly="True">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="TIME (UTC)" Binding="{Binding Timestamp}" Width="150"/>
                                <DataGridTextColumn Header="MACHINE" Binding="{Binding MachineName}" Width="130"/>
                                <DataGridTextColumn Header="PROCESS" Binding="{Binding ProcessPath}" Width="220"/>
                                <DataGridTextColumn Header="PUBLISHER" Binding="{Binding DetectedPublisher}" Width="160"/>
                                <DataGridTemplateColumn Header="SIGNED" Width="70" SortMemberPath="WasSignedMatch">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Ellipse Width="10" Height="10" HorizontalAlignment="Center">
                                                <Ellipse.Style>
                                                    <Style TargetType="Ellipse">
                                                        <Setter Property="Fill" Value="{StaticResource AccentRedBrush}"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding WasSignedMatch}" Value="True">
                                                                <Setter Property="Fill" Value="{StaticResource AccentGreenBrush}"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Ellipse.Style>
                                            </Ellipse>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTextColumn Header="RULE" Binding="{Binding MatchedRuleName}" Width="120"/>
                                <DataGridTextColumn Header="ACTION TAKEN" Binding="{Binding ActionTaken}" Width="150"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </TabItem>

                <!-- ========== Users tab ========== -->
                <TabItem Header="USERS">
                    <Grid Margin="0,12,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="12"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0" Style="{StaticResource Card}" Background="{StaticResource TableHeaderBgBrush}" Padding="12">
                            <StackPanel Orientation="Horizontal">
                                <TextBox x:Name="NewUserUsernameBox" Width="160" Margin="0,0,8,0"
                                         ToolTip="Username"/>
                                <PasswordBox x:Name="NewUserPasswordBox" Width="160" Margin="0,0,8,0"
                                             ToolTip="Password (อย่างน้อย 8 ตัวอักษร)"/>
                                <Button Content="ADD USER" Style="{StaticResource PrimaryButton}"
                                        Click="AddUserButton_Click"/>
                            </StackPanel>
                        </Border>

                        <DataGrid Grid.Row="2" x:Name="UsersGrid" AutoGenerateColumns="False" IsReadOnly="True">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="USERNAME" Binding="{Binding Username}" Width="150"/>
                                <DataGridTextColumn Header="BUILT-IN" Binding="{Binding IsBuiltIn}" Width="80"/>
                                <DataGridTextColumn Header="DEFAULT PASSWORD" Binding="{Binding HasDefaultPassword}" Width="130"/>
                                <DataGridTextColumn Header="CREATED (UTC)" Binding="{Binding CreatedAt}" Width="160"/>
                                <DataGridTextColumn Header="LAST LOGIN (UTC)" Binding="{Binding LastLoginAt}" Width="160"/>
                                <DataGridTemplateColumn Header="ACTIONS" Width="200">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal">
                                                <!--
                                                    ปุ่ม RESET PW: ใช้ได้กับทุก account รวม built-in
                                                    (ต่างจาก DELETE ที่ต้องกันไว้เพราะลบ built-in ไม่ได้เลย)
                                                -->
                                                <Button Content="RESET PW" Tag="{Binding}"
                                                        Click="ResetUserPasswordButton_Click"
                                                        Style="{StaticResource SmallActionButton}"
                                                        Margin="0,0,4,0"/>

                                                <!--
                                                    ปุ่ม DELETE: disable ถ้าเป็น built-in account (กัน lockout)
                                                    ใช้ DataTrigger เทียบ IsBuiltIn แทนการเขียน converter class ใหม่
                                                -->
                                                <Button Content="DELETE" Tag="{Binding Id}"
                                                        Click="DeleteUserButton_Click">
                                                    <Button.Style>
                                                        <Style TargetType="Button" BasedOn="{StaticResource DangerSmallActionButton}">
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsBuiltIn}" Value="True">
                                                                    <Setter Property="IsEnabled" Value="False"/>
                                                                    <Setter Property="ToolTip" Value="ลบ built-in account ไม่ได้"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Button.Style>
                                                </Button>
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </TabItem>

            </TabControl>
        </Border>

        <!-- ==================== Footer status bar ==================== -->
        <Border Grid.Row="4" CornerRadius="12"
                Background="{StaticResource Brush.Background.Card}"
                BorderBrush="{StaticResource Brush.Border.Default}"
                BorderThickness="1" Padding="16,10">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Server:" Style="{StaticResource Label}" Margin="0,0,4,0"/>
                <TextBlock x:Name="FooterServerText" Style="{StaticResource Caption}" VerticalAlignment="Center"/>
                <TextBlock Text="User:" Style="{StaticResource Label}" Margin="24,0,4,0"/>
                <TextBlock x:Name="FooterUserText" Style="{StaticResource Caption}" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
