<Window x:Class="OnionProcOparetor.Console.DashboardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Onion ProcOparetor Console - Dashboard"
        Height="640" Width="1000"
        WindowStartupLocation="CenterScreen"
        Style="{StaticResource DarkWindowStyle}">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ==================== Top bar ==================== -->
        <Border Grid.Row="0" Style="{StaticResource Card}" Padding="16,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <TextBlock Text="Onion ProcOparetor" FontWeight="Bold" FontSize="16" VerticalAlignment="Center"/>
                    <TextBlock x:Name="ServerLabel" Text="" Style="{StaticResource LabelText}"
                               Margin="12,0,0,0" VerticalAlignment="Center" FontSize="12"/>
                </StackPanel>

                <TextBlock Grid.Column="2" x:Name="StatusText" Style="{StaticResource LabelText}"
                           VerticalAlignment="Center" Margin="0,0,16,0"/>

                <StackPanel Grid.Column="3" Orientation="Horizontal">
                    <Button x:Name="GlobalToggleButton" Content="TOGGLE GLOBAL"
                            Style="{StaticResource SecondaryButton}" Margin="0,0,8,0"
                            Click="GlobalToggleButton_Click"/>
                    <Button x:Name="RefreshButton" Content="REFRESH"
                            Style="{StaticResource PrimaryButton}"
                            Click="RefreshButton_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ==================== Main content ==================== -->
        <Border Grid.Row="2" Style="{StaticResource Card}" Padding="0">
            <TabControl Background="Transparent" BorderThickness="0" Margin="16">

                <!-- ========== Clients tab ========== -->
                <TabItem Header="CLIENTS">
                    <Grid Margin="0,12,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="8"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Orientation="Horizontal">
                            <TextBox x:Name="ClientsSearchBox" Width="250"
                                    Tag="ค้นหา machine name..." TextChanged="ClientsSearchBox_TextChanged"/>
                            <Button Content="TOGGLE SELECTED" Style="{StaticResource SmallActionButton}"
                                    Margin="12,0,0,0" Click="ToggleSelectedClientsButton_Click"/>
                            <TextBlock x:Name="SelectedClientsCountText" VerticalAlignment="Center" Margin="8,0,0,0"
                                    Foreground="{StaticResource TextPrimaryBrush}" Text=""/>
                        </StackPanel>

                        <DataGrid Grid.Row="2" x:Name="ClientsGrid" AutoGenerateColumns="False" IsReadOnly="True"
                                SelectionMode="Extended" SelectionUnit="FullRow"
                                SelectionChanged="ClientsGrid_SelectionChanged">
                            <DataGrid.Columns>
                                <DataGridTemplateColumn Header="STATUS" Width="80" SortMemberPath="IsOffline">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Ellipse Width="10" Height="10" HorizontalAlignment="Center"
                                                    ToolTip="{Binding LastSeenAt, StringFormat='Last seen: {0:yyyy-MM-dd HH:mm:ss} UTC'}">
                                                <Ellipse.Style>
                                                    <Style TargetType="Ellipse">
                                                        <Setter Property="Fill" Value="{StaticResource AccentRedBrush}"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsEnabled}" Value="True">
                                                                <Setter Property="Fill" Value="{StaticResource AccentGreenBrush}"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding IsOffline}" Value="True">
                                                                <Setter Property="Fill" Value="Gray"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Ellipse.Style>
                                            </Ellipse>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTextColumn Header="MACHINE NAME" Binding="{Binding MachineName}" Width="200"/>
                                <DataGridTextColumn Header="CLIENT GUID" Binding="{Binding ClientGuid}" Width="260"/>
                                <DataGridTextColumn Header="LAST SEEN (UTC)" Binding="{Binding LastSeenAt}" Width="180"/>
                                <DataGridTemplateColumn Header="ACTION" Width="160">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal">
                                                <Button Content="TOGGLE" Style="{StaticResource SmallActionButton}"
                                                        Click="ToggleClientButton_Click" Tag="{Binding Id}" Margin="0,0,4,0"/>
                                                <Button Content="SETTINGS" Style="{StaticResource SmallActionButton}"
                                                        Click="ClientSettingsButton_Click" Tag="{Binding}"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </TabItem>

                <!-- ========== Rules tab ========== -->
                <TabItem Header="RULES">
                    <Grid Margin="0,12,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="12"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="8"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0" Style="{StaticResource Card}" Background="{StaticResource InputBgBrush}" Padding="12">
                            <StackPanel Orientation="Horizontal">
                                <TextBox x:Name="NewRuleNameBox" Width="110" Margin="0,0,8,0"
                                        ToolTip="ชื่อกฎ" Tag="Rule name"/>
                                <TextBox x:Name="NewRulePublisherBox" Width="160" Margin="0,0,8,0"
                                        ToolTip="ชื่อ Publisher เช่น Valve Corporation"/>
                                <TextBox x:Name="NewRuleProcessNameContainsBox" Width="130" Margin="0,0,8,0"
                                        ToolTip="[OPTIONAL] narrow เพิ่มจากชื่อไฟล์ เช่น 'notepad' - เว้นว่างได้ถ้าไม่รู้ชื่อไฟล์ล่วงหน้า"/>
                                <CheckBox x:Name="NewRuleKillCheckBox" Content="Kill Process"
                                        VerticalAlignment="Center" Margin="0,0,8,0" Foreground="{StaticResource TextPrimaryBrush}"/>
                                <TextBox x:Name="NewRuleActionBox" Width="150" Margin="0,0,8,0"
                                        ToolTip="path คำสั่ง/สคริปต์ (ไม่บังคับ)"/>
                                <Button Content="ADD RULE" Style="{StaticResource PrimaryButton}"
                                        Click="AddRuleButton_Click"/>
                            </StackPanel>
                        </Border>

                        <TextBox Grid.Row="2" x:Name="RulesSearchBox" Width="250" HorizontalAlignment="Left"
                                Tag="ค้นหาชื่อกฎ/publisher..." TextChanged="RulesSearchBox_TextChanged"/>

                        <DataGrid Grid.Row="4" x:Name="RulesGrid" AutoGenerateColumns="False" IsReadOnly="True">
                            <DataGrid.Columns>
                                <DataGridTemplateColumn Header="STATUS" Width="80" SortMemberPath="IsEnabled">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Ellipse Width="10" Height="10" HorizontalAlignment="Center">
                                                <Ellipse.Style>
                                                    <Style TargetType="Ellipse">
                                                        <Setter Property="Fill" Value="{StaticResource AccentRedBrush}"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsEnabled}" Value="True">
                                                                <Setter Property="Fill" Value="{StaticResource AccentGreenBrush}"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Ellipse.Style>
                                            </Ellipse>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTextColumn Header="NAME" Binding="{Binding Name}" Width="130"/>
                                <DataGridTextColumn Header="PUBLISHER" Binding="{Binding PublisherName}" Width="170"/>
                                <DataGridTextColumn Header="NAME CONTAINS" Binding="{Binding ProcessNameContains}" Width="110"/>
                                <DataGridTextColumn Header="SIGNED ONLY" Binding="{Binding RequireSignedMatch}" Width="90"/>
                                <DataGridTextColumn Header="KILL" Binding="{Binding KillProcess}" Width="50"/>
                                <DataGridTextColumn Header="ACTION COMMAND" Binding="{Binding ActionCommand}" Width="150"/>
                                <DataGridTemplateColumn Header="ACTIONS" Width="140">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal">
                                                <Button Content="TOGGLE" Style="{StaticResource SmallActionButton}"
                                                        Click="ToggleRuleButton_Click" Tag="{Binding Id}" Margin="0,0,4,0"/>
                                                <Button Content="DELETE" Style="{StaticResource SmallActionButton}"
                                                        Click="DeleteRuleButton_Click" Tag="{Binding Id}"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                             </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </TabItem>

                <!-- ========== Logs tab ========== -->
                <TabItem Header="LOGS">
                    <Grid Margin="0,12,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="8"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <TextBox Grid.Row="0" x:Name="LogsSearchBox" Width="250" HorizontalAlignment="Left"
                                Tag="ค้นหา machine/process/publisher..." TextChanged="LogsSearchBox_TextChanged"/>

                        <DataGrid Grid.Row="2" x:Name="LogsGrid" AutoGenerateColumns="False" IsReadOnly="True">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="TIME (UTC)" Binding="{Binding Timestamp}" Width="150"/>
                                <DataGridTextColumn Header="MACHINE" Binding="{Binding MachineName}" Width="130"/>
                                <DataGridTextColumn Header="PROCESS" Binding="{Binding ProcessPath}" Width="220"/>
                                <DataGridTextColumn Header="PUBLISHER" Binding="{Binding DetectedPublisher}" Width="160"/>
                                <DataGridTemplateColumn Header="SIGNED" Width="70" SortMemberPath="WasSignedMatch">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Ellipse Width="10" Height="10" HorizontalAlignment="Center">
                                                <Ellipse.Style>
                                                    <Style TargetType="Ellipse">
                                                        <Setter Property="Fill" Value="{StaticResource AccentRedBrush}"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding WasSignedMatch}" Value="True">
                                                                <Setter Property="Fill" Value="{StaticResource AccentGreenBrush}"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Ellipse.Style>
                                            </Ellipse>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTextColumn Header="RULE" Binding="{Binding MatchedRuleName}" Width="120"/>
                                <DataGridTextColumn Header="ACTION TAKEN" Binding="{Binding ActionTaken}" Width="150"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </TabItem>

                <!-- ========== Users tab ========== -->
                <TabItem Header="USERS">
                    <Grid Margin="0,12,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="12"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0" Style="{StaticResource Card}" Background="{StaticResource InputBgBrush}" Padding="12">
                            <StackPanel Orientation="Horizontal">
                                <TextBox x:Name="NewUserUsernameBox" Width="160" Margin="0,0,8,0"
                                         ToolTip="Username"/>
                                <PasswordBox x:Name="NewUserPasswordBox" Width="160" Margin="0,0,8,0"
                                             ToolTip="Password (อย่างน้อย 8 ตัวอักษร)"/>
                                <Button Content="ADD USER" Style="{StaticResource PrimaryButton}"
                                        Click="AddUserButton_Click"/>
                            </StackPanel>
                        </Border>

                        <DataGrid Grid.Row="2" x:Name="UsersGrid" AutoGenerateColumns="False" IsReadOnly="True">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="USERNAME" Binding="{Binding Username}" Width="150"/>
                                <DataGridTextColumn Header="BUILT-IN" Binding="{Binding IsBuiltIn}" Width="80"/>
                                <DataGridTextColumn Header="DEFAULT PASSWORD" Binding="{Binding HasDefaultPassword}" Width="130"/>
                                <DataGridTextColumn Header="CREATED (UTC)" Binding="{Binding CreatedAt}" Width="160"/>
                                <DataGridTextColumn Header="LAST LOGIN (UTC)" Binding="{Binding LastLoginAt}" Width="160"/>
                                <DataGridTemplateColumn Header="ACTIONS" Width="200">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal">
                                                <!--
                                                    ปุ่ม RESET PW: ใช้ได้กับทุก account รวม built-in
                                                    (ต่างจาก DELETE ที่ต้องกันไว้เพราะลบ built-in ไม่ได้เลย)
                                                -->
                                                <Button Content="RESET PW" Tag="{Binding}"
                                                        Click="ResetUserPasswordButton_Click"
                                                        Style="{StaticResource SmallActionButton}"
                                                        Margin="0,0,4,0"/>

                                                <!--
                                                    ปุ่ม DELETE: disable ถ้าเป็น built-in account (กัน lockout)
                                                    ใช้ DataTrigger เทียบ IsBuiltIn แทนการเขียน converter class ใหม่
                                                -->
                                                <Button Content="DELETE" Tag="{Binding Id}"
                                                        Click="DeleteUserButton_Click">
                                                    <Button.Style>
                                                        <Style TargetType="Button" BasedOn="{StaticResource SmallActionButton}">
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsBuiltIn}" Value="True">
                                                                    <Setter Property="IsEnabled" Value="False"/>
                                                                    <Setter Property="ToolTip" Value="ลบ built-in account ไม่ได้"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Button.Style>
                                                </Button>
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </TabItem>

            </TabControl>
        </Border>
    </Grid>
</Window>
