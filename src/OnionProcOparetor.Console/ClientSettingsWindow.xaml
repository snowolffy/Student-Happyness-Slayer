<Window x:Class="OnionProcOparetor.Console.ClientSettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Client Settings"
        Height="280" Width="420"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Style="{StaticResource AppWindowStyle}">
    <!-- Free-form Canvas layout - drag any element to reposition it in the VS Designer. -->
    <Canvas Margin="20">
        <TextBlock Canvas.Left="0" Canvas.Top="0" x:Name="MachineNameText" Style="{StaticResource Heading2}"/>

        <Border Canvas.Left="0" Canvas.Top="32" Width="380" Height="110" CornerRadius="10" Padding="14"
                Background="{StaticResource Brush.Background.Primary}"
                BorderBrush="{StaticResource Brush.Border.Default}" BorderThickness="1">
            <Canvas>
                <TextBlock Canvas.Left="0" Canvas.Top="0" Text="POLL INTERVAL OVERRIDE (seconds)" Style="{StaticResource Label}"/>
                <TextBlock Canvas.Left="0" Canvas.Top="18" Width="352"
                           Text="Leave empty to use the Agent's own default (usually 30s)."
                           Style="{StaticResource Caption}" TextWrapping="Wrap"/>
                <TextBox Canvas.Left="0" Canvas.Top="52" Width="120" x:Name="PollIntervalOverrideBox"
                         Style="{StaticResource RoundedTextBox}"/>
            </Canvas>
        </Border>

        <TextBlock Canvas.Left="0" Canvas.Top="152" Width="380" x:Name="StatusText" Style="{StaticResource Caption}" TextWrapping="Wrap"/>

        <Button Canvas.Left="84" Canvas.Top="204" Width="120" Content="CLEAR OVERRIDE" Style="{StaticResource ButtonSecondary}"
                Padding="10,5" FontSize="11" Click="ClearOverrideButton_Click"/>
        <Button Canvas.Left="212" Canvas.Top="204" Width="80" Content="SAVE" Style="{StaticResource ButtonPrimary}"
                Click="SaveButton_Click"/>
        <Button Canvas.Left="300" Canvas.Top="204" Width="80" Content="CANCEL" Style="{StaticResource ButtonSecondary}"
                Padding="10,5" FontSize="11" Click="CancelButton_Click"/>
    </Canvas>
</Window>
