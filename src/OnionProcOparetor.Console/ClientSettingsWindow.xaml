<Window x:Class="OnionProcOparetor.Console.ClientSettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Client Settings"
        Height="280" Width="420"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Style="{StaticResource AppWindowStyle}">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" x:Name="MachineNameText" FontSize="16" FontWeight="Bold"/>

        <Border Grid.Row="2" Style="{StaticResource Card}" Background="{StaticResource TableHeaderBgBrush}" Padding="14">
            <StackPanel>
                <TextBlock Text="POLL INTERVAL OVERRIDE (seconds)" Style="{StaticResource LabelText}" FontSize="10"/>
                <TextBlock Text="Leave empty to use the Agent's own default (usually 30s)."
                           Style="{StaticResource LabelText}" FontSize="10" Margin="0,2,0,8" TextWrapping="Wrap"/>
                <TextBox x:Name="PollIntervalOverrideBox" Width="120" HorizontalAlignment="Left"/>
            </StackPanel>
        </Border>

        <TextBlock Grid.Row="4" x:Name="StatusText" Style="{StaticResource LabelText}" FontSize="11" TextWrapping="Wrap"/>

        <StackPanel Grid.Row="6" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="CLEAR OVERRIDE" Style="{StaticResource SmallActionButton}"
                    Margin="0,0,8,0" Click="ClearOverrideButton_Click"/>
            <Button Content="SAVE" Style="{StaticResource PrimaryButton}"
                    Margin="0,0,8,0" Click="SaveButton_Click"/>
            <Button Content="CANCEL" Style="{StaticResource SmallActionButton}"
                    Click="CancelButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
