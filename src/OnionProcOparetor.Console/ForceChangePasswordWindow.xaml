<Window x:Class="OnionProcOparetor.Console.ForceChangePasswordWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Onion ProcOparetor Console - เปลี่ยน Password"
        Height="440" Width="420"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Style="{StaticResource AppWindowStyle}">
    <Grid>
        <Border Style="{StaticResource Card}" Margin="24" VerticalAlignment="Center">
            <StackPanel>
                <TextBlock Text="ต้องเปลี่ยน Password" Style="{StaticResource HeaderText}"
                           HorizontalAlignment="Center"/>
                <TextBlock Text="บัญชี Administrator ยังใช้ password ว่างเปล่าอยู่ กรุณาตั้ง password ใหม่ก่อนใช้งานต่อ"
                           Style="{StaticResource LabelText}" TextWrapping="Wrap"
                           HorizontalAlignment="Center" TextAlignment="Center"
                           Margin="0,0,0,24" FontSize="13"/>

                <TextBlock Text="NEW PASSWORD" Style="{StaticResource LabelText}"/>
                <PasswordBox x:Name="NewPasswordBox" Margin="0,0,0,16"/>

                <TextBlock Text="CONFIRM NEW PASSWORD" Style="{StaticResource LabelText}"/>
                <PasswordBox x:Name="ConfirmPasswordBox" Margin="0,0,0,8"/>

                <TextBlock Text="ต้องมีความยาวอย่างน้อย 8 ตัวอักษร" Style="{StaticResource LabelText}"
                           FontSize="11" Margin="0,0,0,16"/>

                <Button x:Name="ChangePasswordButton" Content="CHANGE PASSWORD"
                        Style="{StaticResource PrimaryButton}"
                        Click="ChangePasswordButton_Click"/>

                <TextBlock x:Name="StatusText" Margin="0,16,0,0"
                           TextWrapping="Wrap" HorizontalAlignment="Center"
                           TextAlignment="Center" FontSize="12"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
