<Window x:Class="OnionProcOparetor.Console.ForceChangePasswordWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Onion ProcOparetor Console - เปลี่ยน Password"
        Height="440" Width="420"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Style="{StaticResource AppWindowStyle}">
    <!-- Free-form Canvas layout - drag any element to reposition it in the VS Designer. -->
    <Canvas>
        <Border Canvas.Left="24" Canvas.Top="40" Width="372" Height="360" Style="{StaticResource Card}" Padding="24">
            <Canvas>
                <TextBlock Canvas.Left="0" Canvas.Top="0" Width="324" Text="ต้องเปลี่ยน Password"
                           Style="{StaticResource Heading2}" TextAlignment="Center"/>
                <TextBlock Canvas.Left="0" Canvas.Top="32" Width="324"
                           Text="บัญชี Administrator ยังใช้ password ว่างเปล่าอยู่ กรุณาตั้ง password ใหม่ก่อนใช้งานต่อ"
                           Style="{StaticResource Body}" TextWrapping="Wrap" TextAlignment="Center"/>

                <TextBlock Canvas.Left="0" Canvas.Top="94" Text="NEW PASSWORD" Style="{StaticResource Label}"/>
                <PasswordBox Canvas.Left="0" Canvas.Top="112" Width="324" x:Name="NewPasswordBox" Style="{StaticResource RoundedPasswordBox}"/>

                <TextBlock Canvas.Left="0" Canvas.Top="152" Text="CONFIRM NEW PASSWORD" Style="{StaticResource Label}"/>
                <PasswordBox Canvas.Left="0" Canvas.Top="170" Width="324" x:Name="ConfirmPasswordBox" Style="{StaticResource RoundedPasswordBox}"/>

                <TextBlock Canvas.Left="0" Canvas.Top="210" Width="324" Text="ต้องมีความยาวอย่างน้อย 8 ตัวอักษร"
                           Style="{StaticResource Caption}"/>

                <Button Canvas.Left="0" Canvas.Top="234" Width="324" x:Name="ChangePasswordButton" Content="CHANGE PASSWORD"
                        Style="{StaticResource ButtonPrimary}"
                        Click="ChangePasswordButton_Click"/>

                <TextBlock Canvas.Left="0" Canvas.Top="282" Width="324" x:Name="StatusText" Style="{StaticResource Caption}"
                           TextWrapping="Wrap" TextAlignment="Center"/>
            </Canvas>
        </Border>
    </Canvas>
</Window>
