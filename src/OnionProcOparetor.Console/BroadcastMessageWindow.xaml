<Window x:Class="OnionProcOparetor.Console.BroadcastMessageWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Broadcast Message"
        Height="440" Width="440"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Style="{StaticResource AppWindowStyle}">
    <!-- Free-form Canvas layout - drag any element to reposition it in the VS Designer. -->
    <Canvas Margin="20">
        <TextBlock Canvas.Left="0" Canvas.Top="0" Text="Broadcast Message" Style="{StaticResource Heading2}"/>

        <TextBlock Canvas.Left="0" Canvas.Top="36" Text="หัวข้อ (ไม่บังคับ)" Style="{StaticResource Label}"/>
        <TextBox Canvas.Left="0" Canvas.Top="54" Width="380" x:Name="TitleInputBox"
                 Style="{StaticResource RoundedTextBox}"/>

        <TextBlock Canvas.Left="0" Canvas.Top="94" Text="ข้อความ" Style="{StaticResource Label}"/>
        <TextBox Canvas.Left="0" Canvas.Top="112" Width="380" Height="120" x:Name="MessageInputBox"
                 Style="{StaticResource RoundedTextBox}" TextWrapping="Wrap" AcceptsReturn="True"
                 VerticalScrollBarVisibility="Auto"/>

        <RadioButton Canvas.Left="0" Canvas.Top="248" x:Name="SendToSelectedRadio" GroupName="BroadcastTarget"
                     Content="ส่งไปเครื่องที่เลือกไว้"/>
        <RadioButton Canvas.Left="0" Canvas.Top="274" x:Name="SendToAllRadio" GroupName="BroadcastTarget"
                     Content="ส่งไปทุกเครื่อง"/>

        <TextBlock Canvas.Left="0" Canvas.Top="308" Width="380" x:Name="StatusText" Style="{StaticResource Caption}" TextWrapping="Wrap"/>

        <Button Canvas.Left="222" Canvas.Top="352" Width="70" Content="SEND" Style="{StaticResource ButtonPrimary}"
                Click="SendButton_Click"/>
        <Button Canvas.Left="300" Canvas.Top="352" Width="80" Content="CANCEL" Style="{StaticResource ButtonSecondary}"
                Padding="10,5" FontSize="11" Click="CancelButton_Click"/>
    </Canvas>
</Window>
