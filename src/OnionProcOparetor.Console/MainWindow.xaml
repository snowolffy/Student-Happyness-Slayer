<Window x:Class="OnionProcOparetor.Console.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Onion ProcOparetor Console"
        Height="620" Width="440"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Style="{StaticResource AppWindowStyle}"
        Background="{StaticResource Brush.Background.Primary}">
    <!--
        Free-form Canvas layout: every element below carries an explicit Canvas.Left/Canvas.Top,
        so it can be dragged to a new position directly in the VS XAML Designer. Positions are
        pixel coordinates relative to the Window (or relative to the inner Canvas for elements
        nested inside the card Border) - unlike Grid/StackPanel, nothing here re-flows automatically,
        so if you widen a control, nudge the Canvas.Left of whatever sits to its right.
    -->
    <Canvas>
        <!-- ==================== Logo + title ==================== -->
        <Border Canvas.Left="196" Canvas.Top="32" Width="48" Height="48" CornerRadius="12"
                Background="{StaticResource Brush.Accent.Default}">
            <TextBlock Text="O" FontSize="20" FontWeight="Bold" Foreground="White"
                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
        </Border>
        <TextBlock Canvas.Left="95" Canvas.Top="92" Width="250" Text="Onion ProcOparetor" Style="{StaticResource Heading1}"
                   TextAlignment="Center"/>
        <TextBlock Canvas.Left="145" Canvas.Top="124" Width="150" Text="Server Console" Style="{StaticResource Caption}"
                   TextAlignment="Center"/>

        <!-- ==================== Connect form ==================== -->
        <Border Canvas.Left="24" Canvas.Top="170" Width="392" Height="360" CornerRadius="12"
                Background="{StaticResource Brush.Background.Card}"
                BorderBrush="{StaticResource Brush.Border.Default}"
                BorderThickness="1" Padding="24">
            <Canvas>
                <TextBlock Canvas.Left="0" Canvas.Top="0" Width="344"
                           Text="Please enter your Server IP, Username and Password to connect"
                           Style="{StaticResource Body}" TextWrapping="Wrap" TextAlignment="Center"/>

                <TextBlock Canvas.Left="0" Canvas.Top="52" Text="SERVER IP" Style="{StaticResource Label}"/>
                <TextBox Canvas.Left="0" Canvas.Top="70" Width="242" x:Name="ServerIpBox" Text="localhost" Style="{StaticResource RoundedTextBox}"/>

                <TextBlock Canvas.Left="254" Canvas.Top="52" Text="PORT" Style="{StaticResource Label}"/>
                <TextBox Canvas.Left="254" Canvas.Top="70" Width="90" x:Name="PortBox" Text="8787" Style="{StaticResource RoundedTextBox}"/>

                <TextBlock Canvas.Left="0" Canvas.Top="110" Text="USERNAME" Style="{StaticResource Label}"/>
                <TextBox Canvas.Left="0" Canvas.Top="128" Width="344" x:Name="UsernameBox" Style="{StaticResource RoundedTextBox}"/>

                <TextBlock Canvas.Left="0" Canvas.Top="168" Text="PASSWORD" Style="{StaticResource Label}"/>
                <PasswordBox Canvas.Left="0" Canvas.Top="186" Width="344" x:Name="PasswordBox" Style="{StaticResource RoundedPasswordBox}"/>

                <Button Canvas.Left="0" Canvas.Top="226" Width="344" x:Name="ConnectButton" Content="CONNECT"
                        Style="{StaticResource ButtonPrimary}"
                        Click="ConnectButton_Click"/>

                <TextBlock Canvas.Left="0" Canvas.Top="282" Width="344" x:Name="StatusText"
                           TextWrapping="Wrap" TextAlignment="Center" FontSize="12"/>
            </Canvas>
        </Border>
    </Canvas>
</Window>
