<Window x:Class="OnionProcOparetor.Console.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Onion ProcOparetor Console"
        Height="620" Width="440"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Style="{StaticResource AppWindowStyle}"
        Background="{StaticResource Brush.Background.Primary}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ==================== Logo + title, centered above the card ==================== -->
        <StackPanel Grid.Row="0" HorizontalAlignment="Center" Margin="0,32,0,20">
            <Border Width="48" Height="48" CornerRadius="12"
                    Background="{StaticResource Brush.Accent.Default}"
                    HorizontalAlignment="Center">
                <TextBlock Text="O" FontSize="20" FontWeight="Bold" Foreground="White"
                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <TextBlock Text="Onion ProcOparetor" Style="{StaticResource Heading1}"
                       HorizontalAlignment="Center" TextAlignment="Center" Margin="0,12,0,0"/>
            <TextBlock Text="Server Console" Style="{StaticResource Caption}"
                       HorizontalAlignment="Center" TextAlignment="Center" Margin="0,2,0,0"/>
        </StackPanel>

        <!-- ==================== Connect form ==================== -->
        <Border Grid.Row="1" CornerRadius="12"
                Background="{StaticResource Brush.Background.Card}"
                BorderBrush="{StaticResource Brush.Border.Default}"
                BorderThickness="1" Padding="24"
                Margin="24,0,24,24" VerticalAlignment="Center">
            <StackPanel>
                <TextBlock Text="Please enter your Server IP, Username and Password to connect"
                           Style="{StaticResource Body}" TextWrapping="Wrap"
                           HorizontalAlignment="Center" TextAlignment="Center"
                           Margin="0,0,0,20"/>

                <Grid Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="90"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="SERVER IP" Style="{StaticResource Label}" Margin="0,0,0,4"/>
                        <TextBox x:Name="ServerIpBox" Text="localhost" Style="{StaticResource RoundedTextBox}"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="PORT" Style="{StaticResource Label}" Margin="0,0,0,4"/>
                        <TextBox x:Name="PortBox" Text="8787" Style="{StaticResource RoundedTextBox}"/>
                    </StackPanel>
                </Grid>

                <TextBlock Text="USERNAME" Style="{StaticResource Label}" Margin="0,0,0,4"/>
                <TextBox x:Name="UsernameBox" Style="{StaticResource RoundedTextBox}" Margin="0,0,0,16"/>

                <TextBlock Text="PASSWORD" Style="{StaticResource Label}" Margin="0,0,0,4"/>
                <PasswordBox x:Name="PasswordBox" Style="{StaticResource RoundedPasswordBox}" Margin="0,0,0,24"/>

                <Button x:Name="ConnectButton" Content="CONNECT"
                        Style="{StaticResource ButtonPrimary}"
                        HorizontalAlignment="Stretch"
                        Click="ConnectButton_Click"/>

                <TextBlock x:Name="StatusText" Margin="0,16,0,0"
                           TextWrapping="Wrap" HorizontalAlignment="Center"
                           TextAlignment="Center" FontSize="12"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
