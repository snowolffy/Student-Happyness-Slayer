<Window x:Class="MyLabGuard.ClientTray.StatusWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="MyLabGuard - Status"
        Height="480" Width="560"
        WindowStartupLocation="CenterScreen"
        Background="#0F1115"
        Foreground="#E8E9EB">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Orientation="Horizontal">
            <TextBlock Text="MyLabGuard" FontSize="18" FontWeight="Bold" VerticalAlignment="Center"/>
            <TextBlock x:Name="MachineNameText" FontSize="12" Foreground="#8A8F98"
                       Margin="12,0,0,0" VerticalAlignment="Center"/>
        </StackPanel>

        <!-- Status Card -->
        <Border Grid.Row="2" Background="#1A1D23" BorderBrush="#2A2E37" BorderThickness="1"
                CornerRadius="6" Padding="16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="ENFORCEMENT" FontSize="10" Foreground="#8A8F98"/>
                    <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                        <Ellipse x:Name="EnabledDot" Width="10" Height="10" Fill="#3DD68C"
                                 VerticalAlignment="Center"/>
                        <TextBlock x:Name="EnabledText" Text="Enabled" Margin="6,0,0,0"
                                   FontWeight="SemiBold" VerticalAlignment="Center"/>
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Column="1">
                    <TextBlock Text="RULES" FontSize="10" Foreground="#8A8F98"/>
                    <TextBlock x:Name="RulesCountText" Text="0" FontWeight="SemiBold" Margin="0,4,0,0"/>
                </StackPanel>

                <StackPanel Grid.Column="2">
                    <TextBlock Text="LAST POLL" FontSize="10" Foreground="#8A8F98"/>
                    <TextBlock x:Name="LastPollText" Text="-" FontWeight="SemiBold" Margin="0,4,0,0"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Recent logs -->
        <Border Grid.Row="4" Background="#1A1D23" BorderBrush="#2A2E37" BorderThickness="1"
                CornerRadius="6" Padding="12">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="8"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Orientation="Horizontal">
                    <TextBlock Text="RECENT ACTIVITY" FontSize="10" Foreground="#8A8F98"
                               VerticalAlignment="Center"/>
                    <Button x:Name="RefreshButton" Content="REFRESH" Margin="12,0,0,0"
                            Padding="8,3" FontSize="10" Background="#22252C" Foreground="#E8E9EB"
                            BorderBrush="#2A2E37" BorderThickness="1" Click="RefreshButton_Click"/>
                </StackPanel>

                <ListView Grid.Row="2" x:Name="LogsListView" Background="Transparent"
                          BorderThickness="0" Foreground="#E8E9EB">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="Time" Width="130" DisplayMemberBinding="{Binding Timestamp}"/>
                            <GridViewColumn Header="Process" Width="150" DisplayMemberBinding="{Binding ProcessPath}"/>
                            <GridViewColumn Header="Rule" Width="100" DisplayMemberBinding="{Binding MatchedRuleName}"/>
                            <GridViewColumn Header="Action" Width="120" DisplayMemberBinding="{Binding ActionTaken}"/>
                        </GridView>
                    </ListView.View>
                </ListView>
            </Grid>
        </Border>
    </Grid>
</Window>