<Window x:Class="MyLabGuard.ClientTray.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="MyLabGuard - Login"
        Height="340" Width="360"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#0F1115"
        Foreground="#E8E9EB">
    <Grid Margin="24">
        <StackPanel VerticalAlignment="Center">
            <TextBlock Text="MyLabGuard" FontSize="20" FontWeight="Bold"
                       HorizontalAlignment="Center" Margin="0,0,0,4"/>
            <TextBlock Text="เข้าสู่ระบบเพื่อดูสถานะ" FontSize="12" Foreground="#8A8F98"
                       HorizontalAlignment="Center" Margin="0,0,0,20"/>

            <TextBlock Text="USERNAME" FontSize="11" Foreground="#8A8F98" Margin="0,0,0,4"/>
            <TextBox x:Name="UsernameBox" Padding="8,6" Background="#22252C"
                     Foreground="#E8E9EB" BorderBrush="#2A2E37" Margin="0,0,0,16"/>

            <TextBlock Text="PASSWORD" FontSize="11" Foreground="#8A8F98" Margin="0,0,0,4"/>
            <PasswordBox x:Name="PasswordBox" Padding="8,6" Background="#22252C"
                         Foreground="#E8E9EB" BorderBrush="#2A2E37" Margin="0,0,0,16"/>

            <Button x:Name="LoginButton" Content="LOGIN" Height="36"
                    Background="#4C8DFF" Foreground="White" BorderThickness="0"
                    FontWeight="SemiBold" Click="LoginButton_Click"/>

            <TextBlock x:Name="StatusText" Margin="0,12,0,0" TextWrapping="Wrap"
                       HorizontalAlignment="Center" TextAlignment="Center"
                       FontSize="11" Foreground="#F0555A"/>
        </StackPanel>
    </Grid>
</Window>