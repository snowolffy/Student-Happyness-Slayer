<Window x:Class="OnionProcOparetor.AgentTray.StatusWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Onion ProcOparetor - Status"
        Height="500" Width="560"
        WindowStartupLocation="CenterScreen"
        Style="{StaticResource AppWindowStyle}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ==================== Brand header ==================== -->
        <Border Grid.Row="0" Style="{StaticResource BrandHeaderBar}">
            <StackPanel Orientation="Horizontal">
                <Border Style="{StaticResource LogoPlaceholder}">
                    <TextBlock Style="{StaticResource LogoPlaceholderText}"/>
                </Border>
                <StackPanel Margin="10,0,0,0" VerticalAlignment="Center">
                    <TextBlock Text="Onion ProcOparetor" Style="{StaticResource BrandHeaderTitleText}"/>
                    <TextBlock x:Name="MachineNameText" Style="{StaticResource BrandHeaderSubText}"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <Grid Grid.Row="1" Margin="16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="12"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Status Card -->
            <Border Grid.Row="0" Style="{StaticResource Card}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="ENFORCEMENT" Style="{StaticResource LabelText}"/>
                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                            <Ellipse x:Name="EnabledDot" Width="10" Height="10" Fill="{StaticResource AccentGreenBrush}"
                                     VerticalAlignment="Center"/>
                            <TextBlock x:Name="EnabledText" Text="Enabled" Margin="6,0,0,0"
                                       FontWeight="SemiBold" VerticalAlignment="Center"/>
                        </StackPanel>
                    </StackPanel>

                    <StackPanel Grid.Column="1">
                        <TextBlock Text="RULES" Style="{StaticResource LabelText}"/>
                        <TextBlock x:Name="RulesCountText" Text="0" FontWeight="SemiBold" Margin="0,4,0,0"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <TextBlock Text="LAST POLL" Style="{StaticResource LabelText}"/>
                        <TextBlock x:Name="LastPollText" Text="-" FontWeight="SemiBold" Margin="0,4,0,0"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Recent logs -->
            <Border Grid.Row="2" Style="{StaticResource Card}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="8"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal">
                        <TextBlock Text="RECENT ACTIVITY" Style="{StaticResource LabelText}"
                                VerticalAlignment="Center" Margin="0"/>
                        <Button x:Name="RefreshButton" Content="REFRESH" Margin="12,0,0,0"
                                Style="{StaticResource SecondaryButton}" Click="RefreshButton_Click"/>
                        <Button x:Name="OpenTerminalButton" Content="OPEN LOG TERMINAL" Margin="8,0,0,0"
                                Style="{StaticResource SecondaryButton}" Click="OpenTerminalButton_Click"/>
                    </StackPanel>

                    <ListView Grid.Row="2" x:Name="LogsListView" BorderThickness="1">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="Time" Width="130" DisplayMemberBinding="{Binding Timestamp}"/>
                                <GridViewColumn Header="Process" Width="150" DisplayMemberBinding="{Binding ProcessPath}"/>
                                <GridViewColumn Header="Rule" Width="100" DisplayMemberBinding="{Binding MatchedRuleName}"/>
                                <GridViewColumn Header="Action" Width="120" DisplayMemberBinding="{Binding ActionTaken}"/>
                            </GridView>
                        </ListView.View>
                    </ListView>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
