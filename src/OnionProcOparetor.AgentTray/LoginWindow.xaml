<Window x:Class="OnionProcOparetor.AgentTray.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Onion ProcOparetor - Login"
        Height="380" Width="360"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Style="{StaticResource AppWindowStyle}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource BrandHeaderBar}">
            <StackPanel Orientation="Horizontal">
                <Border Style="{StaticResource LogoPlaceholder}">
                    <TextBlock Style="{StaticResource LogoPlaceholderText}"/>
                </Border>
                <StackPanel Margin="10,0,0,0" VerticalAlignment="Center">
                    <TextBlock Text="Onion ProcOparetor" Style="{StaticResource BrandHeaderTitleText}"/>
                    <TextBlock Text="Agent Status Login" Style="{StaticResource BrandHeaderSubText}"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <Grid Grid.Row="1" Margin="24">
            <StackPanel VerticalAlignment="Center">
                <TextBlock Text="เข้าสู่ระบบเพื่อดูสถานะ" FontSize="12" Style="{StaticResource LabelText}"
                           HorizontalAlignment="Center" Margin="0,0,0,20"/>

                <TextBlock Text="USERNAME" Style="{StaticResource LabelText}"/>
                <TextBox x:Name="UsernameBox" Margin="0,0,0,16"/>

                <TextBlock Text="PASSWORD" Style="{StaticResource LabelText}"/>
                <PasswordBox x:Name="PasswordBox" Margin="0,0,0,16"/>

                <Button x:Name="LoginButton" Content="LOGIN" Height="36"
                        Style="{StaticResource PrimaryButton}" Click="LoginButton_Click"/>

                <TextBlock x:Name="StatusText" Margin="0,12,0,0" TextWrapping="Wrap"
                           HorizontalAlignment="Center" TextAlignment="Center"
                           FontSize="11" Foreground="{StaticResource AccentRedBrush}"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
