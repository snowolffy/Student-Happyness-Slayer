<Window x:Class="OnionProcOparetor.AgentTray.LogTerminalWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Onion ProcOparetor - Log Terminal"
        Height="500" Width="720"
        WindowStartupLocation="CenterScreen"
        Style="{StaticResource AppWindowStyle}">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="8"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal">
            <TextBlock Text="LOG TERMINAL" FontWeight="Bold" Style="{StaticResource LabelText}"
                       VerticalAlignment="Center" Margin="0"/>
            <TextBlock x:Name="AutoRefreshStatusText" Style="{StaticResource LabelText}"
                       Margin="12,0,0,0" VerticalAlignment="Center" Text="auto-refresh: on"/>
            <Button x:Name="PauseButton" Content="PAUSE" Margin="12,0,0,0"
                    Style="{StaticResource SecondaryButton}" Click="PauseButton_Click"/>
        </StackPanel>

        <!-- แผงเทอร์มินัลจงใจให้เป็นพื้นดำ/ตัวหนังสือเขียวเหมือนคอนโซลจริง ต่างจากธีมหลักของแอปโดยตั้งใจ -->
        <Border Grid.Row="2" Background="#0A0A0A" BorderBrush="{StaticResource CardBorderBrush}" BorderThickness="1">
            <ScrollViewer x:Name="LogScrollViewer" Padding="10"
                          VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
                <TextBlock x:Name="LogTerminalText"
                           FontFamily="Consolas" FontSize="12"
                           Foreground="#3DD68C" Background="Transparent"
                           TextWrapping="NoWrap"/>
            </ScrollViewer>
        </Border>
    </Grid>
</Window>
